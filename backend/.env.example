# ============================================
# BITVORA EXCHANGE — Backend Environment Variables
# ============================================

# --- Environment ---
ENVIRONMENT=development

# --- Domain ---
BITVORA_DOMAIN=https://bitvora.in

# --- Database (Supabase PostgreSQL — async driver) ---
# Get your connection string from: Supabase Dashboard → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your Supabase DB password
# Format: postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bitvora

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Exchange Rate ---
INR_RATE=83.50

# --- Supported Chains ---
SUPPORTED_CHAINS=ethereum,bsc,tron,bitcoin

# --- Telegram Group Notifications ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=your_group_id_here
TELEGRAM_ADMIN_IDS=

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
MAX_PENDING_TRANSACTIONS_PER_USER=3

# --- DB Pool Tuning ---
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis Tuning ---
REDIS_MAX_CONNECTIONS=50
REDIS_LOCK_TIMEOUT=60

# --- RPC Endpoints ---
RPC_ETHEREUM=https://eth.llamarpc.com
RPC_BSC=https://bsc-dataseed.binance.org
RPC_TRON=https://api.trongrid.io
RPC_BITCOIN=https://blockstream.info/api

# --- Deposit Addresses (One per chain) ---
DEPOSIT_ADDRESS_ETHEREUM=0x4e6d12bFB48Fa0dBc853D3D4D437644968c83112
DEPOSIT_ADDRESS_BSC=0x4e6d12bFB48Fa0dBc853D3D4D437644968c83112
DEPOSIT_ADDRESS_TRON=TMWkeKaA5h1xouHCf196BkVQyq434zS4TQ
DEPOSIT_ADDRESS_BITCOIN=bc1peqlz3wsuw37u27q85pcp0xprs3xjm4xs23d6lfrq4pcqr59dguwsw8unhf
