# ============================================
# BITVORA EXCHANGE — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Environment ---
ENVIRONMENT=production

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Cloudflare ---
CLOUDFLARE_TUNNEL_SECRET=your-cloudflare-tunnel-secret

# --- Admin ---
ADMIN_SECRET_KEY=your-admin-secret-key

# --- Telegram Admin Bot ---
TG_BOT_TOKEN=your-bot-token-from-botfather
TG_CHAT_ID=your-admin-group-chat-id
TG_ADMIN_IDS=12345678,98765432 # Your personal TG ID(s)

# --- AI & Services ---
GEMINI_API_KEY=your-google-gemini-api-key

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
MAX_PENDING_TRANSACTIONS_PER_USER=3

# --- RPC Endpoints (Free Public) ---
RPC_ETHEREUM=https://eth.llamarpc.com
RPC_BSC=https://bsc-dataseed.binance.org
RPC_POLYGON=https://polygon-rpc.com
RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
RPC_TRON=https://api.trongrid.io
RPC_SOLANA=https://api.mainnet-beta.solana.com
RPC_TON=https://toncenter.com/api/v2
RPC_BITCOIN=https://blockstream.info/api

# --- Deposit Addresses (One per chain) ---
DEPOSIT_ADDRESS_ETHEREUM=0x0000000000000000000000000000000000000000
DEPOSIT_ADDRESS_BSC=0x0000000000000000000000000000000000000000
DEPOSIT_ADDRESS_POLYGON=0x0000000000000000000000000000000000000000
DEPOSIT_ADDRESS_ARBITRUM=0x0000000000000000000000000000000000000000
DEPOSIT_ADDRESS_AVALANCHE=0x0000000000000000000000000000000000000000
DEPOSIT_ADDRESS_TRON=T0000000000000000000000000000000000
DEPOSIT_ADDRESS_SOLANA=11111111111111111111111111111111
DEPOSIT_ADDRESS_TON=EQ0000000000000000000000000000000000000000000000
DEPOSIT_ADDRESS_BITCOIN=bc1q0000000000000000000000000000000000000000
